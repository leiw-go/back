# ============================================================
# Backend - 基于本地 jenkins 镜像（Docker Hub 不可达；原多阶段 Dockerfile 无法使用）
#   先在本机执行 mvn package 生成 target/ProjectInfomationManage.jar，
#   再 docker build -f Dockerfile.host -t leiw-go/back:latest .
# ============================================================
FROM docker.m.daocloud.io/jenkins/jenkins:lts-jdk17
WORKDIR /app
COPY target/ProjectInfomationManage.jar /app/app.jar
EXPOSE 8888
ENTRYPOINT ["java","-jar","/app/app.jar"]