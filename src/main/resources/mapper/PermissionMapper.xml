<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaowenltd.projectinfomationmanage.mapper.PermissionMapper">

    <resultMap id="PermissionResultMap" type="Permission">
        <id column="id" property="id"/>
        <result column="permission_name" property="permissionName"/>
        <result column="permission_code" property="permissionCode"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, permission_name, permission_code, description, create_time
    </sql>

    <insert id="insertPermission" parameterType="Permission">
        INSERT INTO t_permission (id, permission_name, permission_code, description, create_time)
        VALUES (#{id}, #{permissionName}, #{permissionCode}, #{description}, #{createTime})
    </insert>

    <delete id="deletePermissionById">
        DELETE FROM t_permission WHERE id = #{id}
    </delete>

    <select id="findPermissionById" resultMap="PermissionResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_permission WHERE id = #{id}
    </select>

    <select id="findAllPermissions" resultMap="PermissionResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_permission ORDER BY permission_code
    </select>

    <select id="findPermissionsByRoleId" resultMap="PermissionResultMap">
        SELECT p.id, p.permission_name, p.permission_code, p.description, p.create_time
        FROM t_permission p
        INNER JOIN t_role_permission rp ON p.id = rp.permission_id
        WHERE rp.role_id = #{roleId}
    </select>

</mapper>
