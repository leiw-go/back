<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaowenltd.projectinfomationmanage.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="Product">
        <id column="id" property="id"/>
        <result column="product_name" property="productName"/>
        <result column="product_code" property="productCode"/>
        <result column="category" property="category"/>
        <result column="description" property="description"/>
        <result column="price" property="price"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, product_name, product_code, category, description, price, status, create_time, update_time
    </sql>

    <insert id="insertProduct" parameterType="Product">
        INSERT INTO t_product (id, product_name, product_code, category, description, price, status, create_time, update_time)
        VALUES (#{id}, #{productName}, #{productCode}, #{category}, #{description}, #{price}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="updateProduct" parameterType="Product">
        UPDATE t_product
        <set>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="productCode != null">product_code = #{productCode},</if>
            <if test="category != null">category = #{category},</if>
            <if test="description != null">description = #{description},</if>
            <if test="price != null">price = #{price},</if>
            <if test="status != null">status = #{status},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteProductById">
        DELETE FROM t_product WHERE id = #{id}
    </delete>

    <select id="findProductById" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_product WHERE id = #{id}
    </select>

    <select id="findAllProducts" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_product ORDER BY create_time DESC
    </select>

</mapper>
