<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaowenltd.projectinfomationmanage.mapper.RolePermissionMapper">

    <resultMap id="RolePermissionResultMap" type="RolePermission">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="permission_id" property="permissionId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insertRolePermission" parameterType="RolePermission">
        INSERT INTO t_role_permission (id, role_id, permission_id, create_time)
        VALUES (#{id}, #{roleId}, #{permissionId}, #{createTime})
    </insert>

    <delete id="deleteRolePermissionByRoleId">
        DELETE FROM t_role_permission WHERE role_id = #{roleId}
    </delete>

    <select id="findRolePermissionsByRoleId" resultMap="RolePermissionResultMap">
        SELECT id, role_id, permission_id, create_time FROM t_role_permission WHERE role_id = #{roleId}
    </select>

</mapper>
